From 1892678ebfb03c62ce821d80762b1dfadd89af76 Mon Sep 17 00:00:00 2001
From: redraz <redrazlive@gmail.com>
Date: Sun, 5 Apr 2026 04:49:26 +0300
Subject: [PATCH] Fix old homebrews

---
 libraries/libmesosphere/source/kern_k_scheduler.cpp       | 8 +-------
 .../vapours/svc/arch/arm/svc_thread_local_region.hpp      | 4 +---
 .../vapours/svc/arch/arm64/svc_thread_local_region.hpp    | 4 +---
 3 files changed, 3 insertions(+), 13 deletions(-)

diff --git a/libraries/libmesosphere/source/kern_k_scheduler.cpp b/libraries/libmesosphere/source/kern_k_scheduler.cpp
index e39eab8c9..d5dfbfcef 100644
--- a/libraries/libmesosphere/source/kern_k_scheduler.cpp
+++ b/libraries/libmesosphere/source/kern_k_scheduler.cpp
@@ -270,13 +270,7 @@ namespace ams::kern {
         m_current_thread = next_thread;
 
         /* Set the new Thread Local region. */
-        const auto tls_address = GetInteger(next_thread->GetThreadLocalRegionAddress());
-        cpu::SwitchThreadLocalRegion(tls_address);
-
-        /* Update the thread's cpu time differential in TLS, if relevant. */
-        if (tls_address != 0) {
-            static_cast<ams::svc::ThreadLocalRegion *>(next_thread->GetThreadLocalRegionHeapAddress())->thread_cpu_time = next_thread->GetCpuTime() - cur_tick;
-        }
+        cpu::SwitchThreadLocalRegion(GetInteger(next_thread->GetThreadLocalRegionAddress()));
     }
 
     void KScheduler::ClearPreviousThread(KThread *thread) {
diff --git a/libraries/libvapours/include/vapours/svc/arch/arm/svc_thread_local_region.hpp b/libraries/libvapours/include/vapours/svc/arch/arm/svc_thread_local_region.hpp
index 69caab7c4..f622a3103 100644
--- a/libraries/libvapours/include/vapours/svc/arch/arm/svc_thread_local_region.hpp
+++ b/libraries/libvapours/include/vapours/svc/arch/arm/svc_thread_local_region.hpp
@@ -25,11 +25,9 @@ namespace ams::svc::arch::arm {
         u32 message_buffer[MessageBufferSize / sizeof(u32)];
         volatile u16 disable_count;
         volatile u16 interrupt_flag;
-        volatile u8 cache_maintenance_flag;
-        volatile s64 thread_cpu_time;
         volatile ams::svc::Handle thread_handle;
         /* TODO: Should we bother adding the Nintendo aarch32 thread local context here? */
-        uintptr_t TODO[(0x200 - 0x114) / sizeof(uintptr_t)];
+        u8 padding[0x200 - 0x104 - sizeof(ams::svc::Handle)];
     };
 
     ALWAYS_INLINE ThreadLocalRegion *GetThreadLocalRegion() {
diff --git a/libraries/libvapours/include/vapours/svc/arch/arm64/svc_thread_local_region.hpp b/libraries/libvapours/include/vapours/svc/arch/arm64/svc_thread_local_region.hpp
index 390d3cb0f..97b6ab3ed 100644
--- a/libraries/libvapours/include/vapours/svc/arch/arm64/svc_thread_local_region.hpp
+++ b/libraries/libvapours/include/vapours/svc/arch/arm64/svc_thread_local_region.hpp
@@ -26,15 +26,13 @@ namespace ams::svc::arch::arm64 {
         volatile u16 disable_count;
         volatile u16 interrupt_flag;
         volatile u8 cache_maintenance_flag;
-        volatile s64 thread_cpu_time;
         volatile ams::svc::Handle thread_handle;
         /* TODO: How should we handle libnx vs Nintendo user thread local space? */
-        uintptr_t TODO[(0x200 - 0x114) / sizeof(uintptr_t)];
+        u8 padding[0x200 - 0x108 - sizeof(ams::svc::Handle)];
     };
     static_assert(__builtin_offsetof(ThreadLocalRegion, disable_count)          == 0x100);
     static_assert(__builtin_offsetof(ThreadLocalRegion, interrupt_flag)         == 0x102);
     static_assert(__builtin_offsetof(ThreadLocalRegion, cache_maintenance_flag) == 0x104);
-    static_assert(__builtin_offsetof(ThreadLocalRegion, thread_cpu_time)        == 0x108);
 
     ALWAYS_INLINE ThreadLocalRegion *GetThreadLocalRegion() {
         ThreadLocalRegion *tlr;
-- 
